# ─── Supabase ───────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API (populated in M1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI ─────────────────────────────────────────────────────────────
# During M-fast: users paste their own key into sessionStorage in-app
# (same as legacy prototype). This server-side var is unused until M2,
# when the /api/ai/generate route moves the key server-side.
OPENAI_API_KEY=

# ─── Resend (transactional email) ───────────────────────────────────────
# Populated in M2. Used for invite emails; Supabase Auth uses the same
# key via SMTP for magic-link delivery.
RESEND_API_KEY=

# ─── PostHog (product analytics) ────────────────────────────────────────
# Populated in M5. Client-side instrumentation only.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Sentry (error monitoring) ──────────────────────────────────────────
# Populated in M5. Used in both client and server bundles.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── App config ─────────────────────────────────────────────────────────
# Canonical URL used by magic links, OG images, email templates.
# Local dev: http://localhost:3000
# Preview (M-preview): https://<deployment>.vercel.app
# Production (M6): https://zhouyixiaoxiao.org
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Preview password gate (M-preview only) ─────────────────────────────
# Single shared password for the Vercel preview deploy. Not real auth.
# Set to any value; delete this section when real auth lands in M2.
PREVIEW_PASSWORD=
